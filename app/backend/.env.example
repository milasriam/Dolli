# DolliApp backend environment template
# Copy this file to app/backend/.env for local or staging setup.

# Core app
DEBUG=false
HOST=0.0.0.0
PORT=8000

# Public URLs
FRONTEND_URL=https://staging.yourdomain.kz
# Canonical browser origin for social share redirects (OG landing at /api/share/campaign/{id} → SPA).
# Prefer FRONTEND_PUBLIC_URL; VITE_FRONTEND_URL is accepted as a fallback.
FRONTEND_PUBLIC_URL=https://staging.yourdomain.kz
BACKEND_PUBLIC_URL=https://api-staging.yourdomain.kz
PYTHON_BACKEND_URL=https://api-staging.yourdomain.kz

# Database
DATABASE_URL=postgresql+asyncpg://USER:PASSWORD@HOST:5432/DATABASE

# Auth and JWT
JWT_SECRET_KEY=replace-with-a-long-random-secret
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080

# Email/password login on /login (POST /api/v1/auth/local-login) — required on staging if you use the Sign In form
ALLOW_PASSWORD_AUTH=true
LOCAL_LOGIN_EMAIL=owner@example.com
LOCAL_LOGIN_PASSWORD=change-me-strong-password
# LOCAL_LOGIN_USER_ID=owner-user
# LOCAL_LOGIN_USER_NAME=Owner
# LOCAL_LOGIN_USER_ROLE=admin

# OIDC
OIDC_ISSUER_URL=https://your-oidc-provider
OIDC_CLIENT_ID=your-staging-client-id
OIDC_CLIENT_SECRET=your-staging-client-secret
OIDC_SCOPE=openid profile email

# AI hub (OpenAI-compatible base URL + key) — used by /api/v1/aihub/* and /api/v1/campaigns/ai-draft
# APP_AI_BASE_URL=https://api.openai.com/v1
# APP_AI_KEY=sk-...

# Campaign AI assistant on create flow (server-side validated draft). Set false to hide/disable usage via API.
# ENABLE_CAMPAIGN_AI=true
# Per-user rate limits (in-process; reset on deploy). Tune to protect margin.
# CAMPAIGN_AI_MAX_PER_HOUR=40
# CAMPAIGN_AI_MAX_BURST_PER_MINUTE=10

# Cover image uploads (presign PUT). Required for “upload to our storage” in create flow.
# DOLLI_COVER_UPLOAD_BUCKET=your-oss-bucket
# DOLLI_COVER_PUBLIC_BASE_URL=https://cdn.example.com   # optional if storage JSON returns access_url

# Campaign creation (prod/staging): require ≥1 paid donation per user. Set true only for local/dev.
# ALLOW_CAMPAIGN_CREATE_WITHOUT_DONATION=true

# Real “working” campaign for Dolli development (infra, product). Idempotent on startup.
# ENABLE_PLATFORM_DEV_CAMPAIGN=false   # force off
# ENABLE_PLATFORM_DEV_CAMPAIGN=true    # force on (use on production if you want it public)
# When unset: on only if ENVIRONMENT/APP_ENV looks like staging, dev, development, or local; off otherwise and always off for production|prod|live.
# PLATFORM_DEV_CAMPAIGN_TITLE=Dolli — fund platform development
# PLATFORM_DEV_CAMPAIGN_USER_ID=system-seed-user
# PLATFORM_DEV_CAMPAIGN_GOAL=25000
# PLATFORM_DEV_CAMPAIGN_DESCRIPTION=Custom markdown/plain text…
# PLATFORM_DEV_CAMPAIGN_IMAGE_URL=https://…

# Admin bootstrap
ADMIN_USER_ID=your-admin-platform-user-id
ADMIN_USER_EMAIL=your-admin-email@example.com
MGX_IGNORE_INIT_ADMIN=0

# Domain allowlist
ALLOWED_ORIGINS=https://staging.yourdomain.kz,http://127.0.0.1:3000,http://127.0.0.1:3001
ALLOWED_DOMAINS=staging.yourdomain.kz,api-staging.yourdomain.kz

# If ALLOWED_ORIGINS is empty: CORS defaults are chosen by channel so staging ≠ prod (no cross-environment browser access).
# Set one of: ENVIRONMENT=staging | production, or FRONTEND_URL / BACKEND_PUBLIC_URL (api-staging vs api), or DOLLI_CORS_CHANNEL=staging|prod
# If you set ALLOWED_ORIGINS explicitly and users may open the SPA over HTTP, include both schemes, e.g. https://staging.dolli.space,http://staging.dolli.space

# Halyk EPAY
HALYK_EPAY_CLIENT_ID=your-halyk-client-id
HALYK_EPAY_CLIENT_SECRET=your-halyk-client-secret
HALYK_EPAY_TERMINAL_ID=your-halyk-terminal-id
HALYK_EPAY_CURRENCY=KZT
HALYK_EPAY_OAUTH_URL=https://test-epay.homebank.kz/oauth2/token
HALYK_EPAY_SCRIPT_URL=https://test-epay.homebank.kz/payform/payment-api.js
HALYK_EPAY_STATUS_TOKEN_URL=https://test-epay.homebank.kz/oauth2/token
HALYK_EPAY_STATUS_URL=https://test-epay.homebank.kz/operation-api/api/transactions/status

# Platform fee (basis points, 100 = 1%). Used when resolving organizer tier at payment init; wire into payout/split when ready.
# PLATFORM_FEE_BPS_INDIVIDUAL=300
# PLATFORM_FEE_BPS_VERIFIED_ORGANIZATION=500

# Kaspi Pay
KASPI_PAY_REMOTE_LINK=https://your-kaspi-payment-link

# Donation receipt email (optional). When SMTP_HOST is unset, receipts are logged only.
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=
# SMTP_FROM=no-reply@yourdomain.kz
# SMTP_USE_TLS=true

# Legacy Stripe keys are intentionally omitted from the new staging path.
