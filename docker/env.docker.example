# Copy to docker/.env.docker (gitignored) and adjust:
#   cp docker/env.docker.example docker/.env.docker
# docker compose reads docker/.env.docker via env_file in docker-compose.yml

# Required for JWT
JWT_SECRET_KEY=change-me-to-a-long-random-string-for-docker-only

# Optional: Google OIDC (otherwise use ALLOW_LOCAL_AUTH below)
# OIDC_ISSUER_URL=https://accounts.google.com
# OIDC_CLIENT_ID=
# OIDC_CLIENT_SECRET=
# OIDC_SCOPE=openid email profile

# Quick local login when OIDC is not set (demo)
ALLOW_LOCAL_AUTH=1

# Email + password register / login
ALLOW_EMAIL_PASSWORD_AUTH=1
ALLOW_PASSWORD_RESET=0
